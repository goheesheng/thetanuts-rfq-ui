# Required - WalletConnect project ID (get from https://cloud.reown.com)
WALLET_CONNECT_PROJECT_ID=

# Required - Referrer address for option trades
REFERRER_ADDRESS=

# RPC URLs per chain (server-side only, proxied to /proxy/rpc/{chainId})
# Falls back to SDK public defaultRpcUrls if not set
# RPC_URL_8453=https://rpc.ankr.com/base/<YOUR_KEY>
# RPC_URL_1=https://rpc.ankr.com/eth/<YOUR_KEY>

# Kyber swap API proxy
KYBER_SWAP_URL=https://web.thetanuts.finance/kyber/
